# Mac MCP Server - Environment Config
# Copy this file to mcp_server/.env and adjust it before exposing the server.

# Bearer token for API authentication.
# Recommended: set this to a long random string and set MCP_ALLOW_NO_AUTH=false.
MCP_API_KEY=change-me-please
MCP_ALLOW_NO_AUTH=false

# Allow shell commands. Disable this if you only want non-shell tools.
MCP_ALLOW_SHELL=true

# Optional default workspace. Defaults to the current user's home directory.
# MAC_MCP_HOME=~/
# WORKDIR=~/

# Rate limiting
RATE_LIMIT_PER_MINUTE=120

# Command timeouts (seconds)
DEFAULT_COMMAND_TIMEOUT_S=120
MAX_COMMAND_TIMEOUT_S=600

# Max output characters
MAX_OUTPUT_CHARS=100000

# HTTP tool settings
HTTP_ALLOWLIST=*
HTTP_HTTPS_ONLY=false
HTTP_MAX_RESPONSE_BYTES=5000000
HTTP_TIMEOUT_S=60

# Browser tool settings
BROWSER_ALLOWLIST=*
BROWSER_HTTPS_ONLY=false
DOWNLOAD_DIR=~/Downloads
MAX_JS_RESULT_CHARS=20000
MAX_HTML_CHARS=200000
MAX_WAIT_S=120
